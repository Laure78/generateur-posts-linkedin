# Variables requises pour le déploiement
# Copie ce fichier et renomme-le .env.local en local
# En production : configure ces variables dans le tableau de bord de ta plateforme (Vercel, etc.)

# === Obligatoire : génération de posts ===
OPENAI_API_KEY=sk-...

# === Optionnel : modèle OpenAI ===
# OPENAI_MODEL=gpt-4o-mini

# === Optionnel : Claude (pour varier les providers) ===
# ANTHROPIC_API_KEY=sk-ant-...

# === Supabase (pour stocker les posts en base) ===
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === Admin (connexion /admin/login) ===
ADMIN_SECRET=ton_mot_de_passe_securise
